# Model config — LiteLLM format (see https://docs.litellm.ai/docs/providers)
# Examples:
#   gemini/gemini-2.0-flash   → GOOGLE_API_KEY
#   openai/gpt-4o             → OPENAI_API_KEY
#   anthropic/claude-sonnet-4-6  → ANTHROPIC_API_KEY
#   ollama/llama3.2           → (local, no key needed)
LITELLM_MODEL=gemini/gemini-2.5-flash

# Set the API key for your chosen provider (only one needed)
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Suppress the LiteLLM/Gemini warning (we use LiteLLM intentionally for multi-provider support)
ADK_SUPPRESS_GEMINI_LITELLM_WARNINGS=true
